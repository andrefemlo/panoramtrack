generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackingLinks      TrackingLink[]
  clickEvents        ClickEvent[]
  whatsappInstances  WhatsAppInstance[]
  leads              Lead[]
  leadAttributions   LeadAttribution[]
  conversations      Conversation[]
  messages           Message[]
  leadStageHistories LeadStageHistory[]
  conversionEvents   ConversionEvent[]
  leadNotes          LeadNote[]
  leadTags           LeadTag[]
  leadTagAssignments LeadTagAssignment[]
}

model TrackingLink {
  id                     String   @id @default(cuid())
  clientId               String
  slug                   String   @unique
  name                   String
  sourcePlatform         String?
  campaignName           String?
  campaignId             String?
  adsetName              String?
  adsetId                String?
  adName                 String?
  adId                   String?
  whatsappPhone          String
  whatsappInitialMessage String
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  client           Client            @relation(fields: [clientId], references: [id])
  clickEvents      ClickEvent[]
  leadAttributions LeadAttribution[]
}

model ClickEvent {
  id                       String @id @default(cuid())
  clientId                 String
  trackingLinkId           String
  clickCode                String @unique
  destinationWhatsappPhone String

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  gclid  String?
  gbraid String?
  wbraid String?
  fbclid String?
  fbc    String?
  fbp    String?

  ipHash    String?
  userAgent String?
  referrer  String?

  clickedAt DateTime @default(now())
  expiresAt DateTime

  isMatched     Boolean   @default(false)
  matchedLeadId String?
  matchedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client           Client            @relation(fields: [clientId], references: [id])
  trackingLink     TrackingLink      @relation(fields: [trackingLinkId], references: [id])
  leadAttributions LeadAttribution[]

  @@index([clientId])
  @@index([trackingLinkId])
  @@index([destinationWhatsappPhone])
  @@index([clickedAt])
  @@index([isMatched])
}

model WhatsAppInstance {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  phoneNumber String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client        Client         @relation(fields: [clientId], references: [id])
  conversations Conversation[]

  @@unique([clientId, name])
  @@index([clientId])
}

model Lead {
  id             String   @id @default(cuid())
  clientId       String
  name           String?
  whatsappLid    String?
  whatsappName     String?
  whatsappPushName String?
  phone          String
  email          String?
  profilePictureUrl String?
  status         String   @default("new")
  source         String   @default("whatsapp")
  firstMessage   String?
  currentStage   String?
  assignedUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client           Client              @relation(fields: [clientId], references: [id])
  attributions     LeadAttribution[]
  conversations    Conversation[]
  messages         Message[]
  stageHistory     LeadStageHistory[]
  conversionEvents ConversionEvent[]
  notes            LeadNote[]
  tagAssignments   LeadTagAssignment[]

  @@unique([clientId, phone])
  @@index([clientId])
  @@index([phone])
  @@index([clientId, whatsappLid])
  @@index([status])
  @@index([currentStage])
}

model LeadAttribution {
  id             String  @id @default(cuid())
  leadId         String
  clientId       String
  trackingLinkId String?
  clickEventId   String?

  sourcePlatform String?
  campaignName   String?
  campaignId     String?
  adsetName      String?
  adsetId        String?
  adName         String?
  adId           String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  gclid  String?
  gbraid String?
  wbraid String?
  fbclid String?
  fbc    String?
  fbp    String?

  matchMethod     String   @default("unknown")
  matchConfidence String   @default("unknown")
  attributedAt    DateTime @default(now())

  lead         Lead          @relation(fields: [leadId], references: [id])
  client       Client        @relation(fields: [clientId], references: [id])
  trackingLink TrackingLink? @relation(fields: [trackingLinkId], references: [id])
  clickEvent   ClickEvent?   @relation(fields: [clickEventId], references: [id])

  @@unique([leadId, clickEventId])
  @@index([leadId])
  @@index([clientId])
  @@index([trackingLinkId])
  @@index([clickEventId])
  @@index([matchMethod])
  @@index([matchConfidence])
}

model Conversation {
  id                 String    @id @default(cuid())
  clientId           String
  leadId             String
  whatsappInstanceId String?
  channel            String    @default("whatsapp")
  externalChatId     String
  leadPhone          String
  status             String    @default("open")
  unreadCount        Int       @default(0)
  readAt             DateTime?
  archivedAt         DateTime?
  pinnedAt           DateTime?
  assignedUserId     String?
  lastMessageAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client           Client            @relation(fields: [clientId], references: [id])
  lead             Lead              @relation(fields: [leadId], references: [id])
  whatsappInstance WhatsAppInstance? @relation(fields: [whatsappInstanceId], references: [id])
  messages         Message[]

  @@unique([clientId, externalChatId])
  @@index([clientId])
  @@index([leadId])
  @@index([leadPhone])
  @@index([status])
}

model Message {
  id                String   @id @default(cuid())
  conversationId    String
  clientId          String
  leadId            String
  externalMessageId String?
  direction         String
  messageType       String   @default("text")
  body              String?
  mediaUrl          String?
  mediaMimeType     String?
  mediaFileName     String?
  fromPhone         String?
  toPhone           String?
  sentAt            DateTime @default(now())
  createdAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])
  lead         Lead         @relation(fields: [leadId], references: [id])

  @@unique([clientId, externalMessageId])
  @@index([conversationId])
  @@index([clientId])
  @@index([leadId])
  @@index([sentAt])
}

model WebhookPayloadSample {
  id                String   @id @default(cuid())
  provider          String
  eventType         String?
  instanceName      String?
  externalMessageId String?
  fromMe            Boolean?
  payload           Json
  createdAt         DateTime @default(now())

  @@index([provider])
  @@index([eventType])
  @@index([instanceName])
  @@index([externalMessageId])
  @@index([createdAt])
}

model LeadStageHistory {
  id        String   @id @default(cuid())
  leadId    String
  clientId  String
  fromStage String?
  toStage   String
  changedBy String?
  source    String   @default("api")
  note      String?
  changedAt DateTime @default(now())
  createdAt DateTime @default(now())

  lead   Lead   @relation(fields: [leadId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@index([leadId])
  @@index([clientId])
  @@index([toStage])
  @@index([changedAt])
}

model ConversionEvent {
  id         String   @id @default(cuid())
  clientId   String
  leadId     String
  eventName  String
  source     String   @default("crm")
  payload    Json?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])
  lead   Lead   @relation(fields: [leadId], references: [id])

  @@index([clientId])
  @@index([leadId])
  @@index([eventName])
  @@index([occurredAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  clientId  String
  leadId    String
  body      String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])
  lead   Lead   @relation(fields: [leadId], references: [id])

  @@index([clientId])
  @@index([leadId])
  @@index([createdAt])
}

model LeadTag {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  slug      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client      Client              @relation(fields: [clientId], references: [id])
  assignments LeadTagAssignment[]

  @@unique([clientId, slug])
  @@index([clientId])
  @@index([slug])
}

model LeadTagAssignment {
  id         String   @id @default(cuid())
  clientId   String
  leadId     String
  tagId      String
  assignedAt DateTime @default(now())

  client Client  @relation(fields: [clientId], references: [id])
  lead   Lead    @relation(fields: [leadId], references: [id])
  tag    LeadTag @relation(fields: [tagId], references: [id])

  @@unique([leadId, tagId])
  @@index([clientId])
  @@index([leadId])
  @@index([tagId])
}
